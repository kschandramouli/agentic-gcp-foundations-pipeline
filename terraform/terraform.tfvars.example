# GCP Project Configuration
gcp_project_id = "your-gcp-project-id"
gcp_region     = "us-central1"

# GitHub Configuration
github_repo_owner = "your-github-username-or-org"
github_repo_name  = "your-github-repo-name"

# Workload Identity Configuration
workload_identity_pool_id      = "github-action-landing"
workload_identity_provider_id  = "github-oidc-provider"

# Service Account Configuration
service_account_id           = "github-action"
service_account_display_name = "GitHub Actions Service Account"

# Admin Google Group — receives roles/editor on the project
# The pipeline service account must be a member of this group in Google Admin
admin_group_email = "agenticadmingroup@cognizant.com"

# IAM Roles to grant directly to the service account (editor is managed via admin_group_email)
iam_roles = [
  # "roles/compute.admin",
  # "roles/storage.admin",
  # "roles/container.admin",
]
